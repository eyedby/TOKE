{
  "manifest_version": 3,
  "name": "A9 TOKE Engine",
  "version": "0.1.0",
"permissions": [
  "declarativeNetRequest",
  "declarativeNetRequestFeedback",
  "storage"
],
  "host_permissions": ["<all_urls>"],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}